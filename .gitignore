# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*~
*.iml

# Flutter / Dart (future)
/build/
/.dart_tool/
/.flutter-plugins
/.flutter-plugins-dependencies
/.pub-cache/
/.pub/

# Android (future)
/android/.gradle/
/android/local.properties
/android/app/build/

# Local backups and scratch
backups/
scratch/

# Claude Code local state (scheduling, plugin metadata) — per-machine,
# should not enter source control.
.claude/

# Worktree used by the claude-jobs skill to stage archive commits on the
# claude-jobs sidecar branch. Lives inside the repo by design but is never
# tracked by main.
.claude-jobs/

# Secrets and local config
.env
.env.local
*.pem
*.key
# …but do track the bundled Mozilla CA trust store — it's public data
# (published at https://curl.se/docs/caextract.html) and the app fails
# HTTPS git ops without it (no system CA store reachable from
# untrusted_app SELinux context on Android).
!assets/ca/cacert.pem
